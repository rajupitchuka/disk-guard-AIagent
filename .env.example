# Copy to .env and fill in. .env is gitignored.

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
OPSGPT_LLM_MODEL=claude-haiku-4-5

# --- Databases ---
# TimescaleDB (telemetry + predictions)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=opsgpt_telemetry
TIMESCALE_USER=opsgpt
TIMESCALE_PASSWORD=opsgpt_dev_password

# pgvector (RAG corpus)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_DB=opsgpt_rag
PGVECTOR_USER=opsgpt
PGVECTOR_PASSWORD=opsgpt_dev_password

# Redis (state + dedup + agent cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Pipeline ---
# Synthetic data generation
SYNTHETIC_HOST_COUNT=3000
SYNTHETIC_TELEMETRY_INTERVAL_MIN=5
SYNTHETIC_HISTORY_DAYS=7

# Ingestion + ML cadence (matches diagram)
INGESTION_INTERVAL_MIN=15
ML_RUN_INTERVAL_MIN=15
ML_PREDICT_HORIZONS_DAYS=1,3,7,14
ML_TRIGGER_FILL_PCT=90
ML_TRIGGER_HORIZON_DAYS=7

# Decision Engine confidence thresholds (matches diagram)
DECISION_AUTO_REMEDIATE_THRESHOLD=0.85
DECISION_OPSGPT_CHAT_THRESHOLD=0.75
# < 0.75 → ServiceNow ticket only

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
